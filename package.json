{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint:md": "markdownlint --ignore node_modules --ignore vendor \"**/*.md\"",
    "format": "prettier \"**/*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}\" --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "prismjs": "^1.29.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.15.0",
    "husky": "^9.1.6",
    "laravel-vite-plugin": "^3.0.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "alpinejs": "^3.15.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.5"
  },
  "engines": {
    "node": ">=20.19 <21 || >=22.12 <23"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}": [
      "prettier --write"
    ],
    "*.php": [
      "php ./vendor/bin/pint --dirty"
    ]
  }
}
