{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint:md": "markdownlint --ignore node_modules --ignore vendor \"**/*.md\"",
    "format": "prettier \"**/*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}\" --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "prismjs": "^1.29.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "husky": "^9.1.6",
    "laravel-vite-plugin": "^3.1.3",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "^0.49.1",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=20.19 <21 || >=22.12 <23"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}": [
      "prettier --write"
    ],
    "*.php": [
      "php ./vendor/bin/pint --dirty"
    ]
  }
}
